# Copie este ficheiro para .env e preencha com os seus valores
# NUNCA commite o ficheiro .env

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Analytics (obter após criar as contas)
VITE_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
VITE_CLARITY_PROJECT_ID="xxxxxxxxxx"

# Pixels de conversão (configurar antes de lançar campanhas pagas)
VITE_META_PIXEL_ID="META-PIXEL-PLACEHOLDER"
VITE_GOOGLE_ADS_ID="AW-PLACEHOLDER"
